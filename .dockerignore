# ── Env files — never copy local dev secrets into images ─────────────────
# Block all .env files by default...
**/.env
**/.env.*
# ...except the web app's production env (VITE_* public vars that Vite reads at build time)
!apps/web/.env.production

# ── Dependencies — re-installed inside the image ──────────────────────────
**/node_modules

# ── Git history — not needed in image ────────────────────────────────────
.git
.gitignore

# ── Local build artifacts ─────────────────────────────────────────────────
**/dist

# ── Misc ──────────────────────────────────────────────────────────────────
.turbo
**/*.log
README.md
